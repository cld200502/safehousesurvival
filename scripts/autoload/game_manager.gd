func consume_time(hours: float) -> bool:
	return _consume_hours(hours)


func consume_actions(count: int) -> bool:
	if count <= 0:
		return false
	# 5%
	modify_hunger(float(-5 * count))
	return _consume_hours(count * ACTION_HOURS)


func get_actions_left() -> int:
	return maxi(0, ACTIONS_PER_DAY - actions_today)


func _consume_hours(hours: float) -> bool:
	if game_over:
		return false
	current_hour += hours
	actions_today += ceili(hours / ACTION_HOURS)
	if current_hour >= 24.0:
		if actions_today >= ACTIONS_PER_DAY:
			current_hour = 24.0
			actions_today = ACTIONS_PER_DAY
			must_sleep = true
			time_changed.emit(current_day, current_hour)
			return false
		current_hour = MORNING_RESET
		current_day += 1
		actions_today = 0
		must_sleep = false
		reset_cat_daily()
		reset_sister_daily()
		do_day_passive()
		npcs_used_today.clear()
		door_cooldown = 0.0
		_update_zombie_level()
		day_changed.emit(current_day)
		time_changed.emit(current_day, current_hour)
		return true
	door_cooldown = maxf(0.0, door_cooldown - hours)
	time_changed.emit(current_day, current_hour)
	return false


