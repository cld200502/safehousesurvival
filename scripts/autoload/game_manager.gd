func process_room_npc_events() -> Array:
	"""NPC夜间行为——每天固定有一个人偷东西"""
	var events: Array = []
	var to_remove: Array = []

	# === 每天固定偷东西（独立于NPC随机事件）===
	var daily_stolen: String = _npc_steal_item()
	if daily_stolen != "":
		events.append("[color=orange]%s[/color]" % daily_stolen)

	var already_stole_today: bool = daily_stolen != ""  # 每天最多一个NPC翻背包

	for i in room_npcs.size():
		var npc: Dictionary = room_npcs[i]
		var roll := randf()
		var ntype: String = npc.get("type", "survivor")
		var name: String = npc.get("name", "???")
		# === 离期到了 ===
		if npc.has("leave_day") and current_day >= npc["leave_day"]:
			events.append("%s收拾行李离开了避难所。" % name)
			to_remove.append(i)
			continue
		# === 变异者暴走 ===
		if ntype == "mutated":
			events.append("[color=red]%s在夜里突然变异！你被咬伤后勉强逃脱。HP-10 精神-10[/color]" % name)
			to_remove.append(i)
			modify_hp(-10)
			modify_sanity(-10)
			continue
		if ntype == "imposter":
			# 冒充者
			if roll < 0.4:
				events.append("[color=red]%s露出獠牙袭击了你！你重伤逃出。HP-20 精神-25[/color]" % name)
				to_remove.append(i)
				modify_hp(-20)
				modify_sanity(-25)
			elif roll < 0.6:
				# 偷东西（上面已处理过每日偷窃，这里是额外）
				events.append("%s鬼鬼祟祟地在你身边转了很久。" % name)
				to_remove.append(i)
			else:
				events.append("%s整晚盯着你，眼神冰冷。" % name)
		elif ntype == "hidden_infected":
			# 隐藏感染者夜间表现
			if roll < 0.25:
				var talks := [
					"%s在梦里呓语着听不懂的话...",
					"%s突然坐起来，又躺下睡了。",
					"%s的手臂上似乎有什么东西在蠕动...",
					"%s的呼吸很不正常...",
				]
				events.append(talks[randi() % talks.size()] % name)
			elif roll < 0.45:
				events.append("%s主动帮你加固了门板。" % name)
				door_hp = mini(door_hp + 10, door_max_hp)
			else:
				events.append("%s睡得很沉，没什么异常。" % name)
		else:
			# 普通幸存者
			# === 被勒索过的报复 ===
			if npc.get("was_extorted", false):
				if randf() < 0.75:
					# 75% 报复离开
					if randf() < 0.5:
						events.append("[color=yellow]%s趁你睡着偷了东西跑了。你醒来时TA已经不见了。[/color]" % name)
					else:
						events.append("[color=yellow]%s连夜离开了避难所，临走前瞪了你一眼。[/color]" % name)
					to_remove.append(i)
					continue
				else:
					# 25% 原谅
					events.append("%s叹了口气：算了，不跟你计较了。" % name)
					npc["was_extorted"] = false
					continue

			if roll < 0.10:
				events.append("[color=red]%s翻脸攻击你！你受了伤。HP-15 精神-20[/color]" % name)
				to_remove.append(i)
				modify_hp(-15)
				modify_sanity(-20)
			elif roll < 0.25:
				# 好事——修门/降低尸潮等级
				events.append("[color=green]%s帮你修补了门框，还清理了外面的丧尸痕迹。[/color]" % name)
				door_hp = mini(door_hp + 15, door_max_hp)
				zombie_level = maxi(1, zombie_level - 1)
			else:
				# 翻背包——每天最多一个NPC翻
				if not already_stole_today:
					already_stole_today = true
					var stole_item_name := _npc_steal_item()
					if stole_item_name != "":
						events.append("[color=orange]%s偷偷翻你的背包，偷走了[%s]！[/color]" % [name, stole_item_name])
					else:
						events.append("[color=orange]%s偷偷翻你的背包，被你发现了，尴尬地笑了笑。[/color]" % name)
					modify_sanity(-5)
				else:
					# 今天已有人翻过，闲聊
					var talks := [
						"半夜听到%s在角落里低声哭泣...",
						"%s给你留了一些食物。",
						"%s说：明天我们一起出去搜物资吧。",
						"%s看起来很焦虑，一整晚没怎么睡。",
					]
					events.append(talks[randi() % talks.size()] % name)

	# 移除离场NPC
	to_remove.sort()
	to_remove.reverse()
	for idx in to_remove:
		room_npcs.remove_at(idx)
	_kicked_npc_names.clear()
	return events


func _npc_steal_item() -> String:
	"""NPC"""
	var stolen_id: String = ""
	var stolen_from: String = ""

	# 70%30%
	if not storage.is_empty() and randf() < 0.7:
		var keys := storage.keys()
		if not keys.is_empty():
			stolen_id = keys[randi() % keys.size()]
			storage[stolen_id] -= 1
			if storage[stolen_id] <= 0:
				storage.erase(stolen_id)
			stolen_from = ""
	elif not trash_bin.is_empty():
		var keys := trash_bin.keys()
		if not keys.is_empty():
			stolen_id = keys[randi() % keys.size()]
			trash_bin[stolen_id] -= 1
			if trash_bin[stolen_id] <= 0:
				trash_bin.erase(stolen_id)
			stolen_from = ""

	if stolen_id == "":
		return ""
	storage_updated.emit()
	var item_name: String = ITEM_DATA.get(stolen_id, {}).get("name", stolen_id)
	return "%s(%s)" % [item_name, stolen_from]


func process_npc_theft() -> String:
	"""NPC70%1
	-1"""
	# 70%
	if randf() >= 0.70:
		return ""
	
	# NPC
	if room_npcs.is_empty():
		return ""
	
	#  + 
	var stealable_items: Array = []
	
	# 
	for item_id in storage:
		if storage[item_id] > 0:
			stealable_items.append({"source": "storage", "item_id": item_id})
	
	# 
	for cab_id in cabinet_items:
		var items: Array = cabinet_items[cab_id]
		for item_id in items:
			stealable_items.append({"source": "cabinet", "item_id": item_id})
	
	if stealable_items.is_empty():
		return ""
	
	# NPC
	var thief: Dictionary = room_npcs[randi() % room_npcs.size()]
	var thief_name: String = thief.get("name", "???")
	
	# 
	var target: Dictionary = stealable_items[randi() % stealable_items.size()]
	var stolen_id: String = target["item_id"]
	var stolen_name: String = ITEM_DATA.get(stolen_id, {}).get("name", stolen_id)
	
	# 
	if target["source"] == "storage":
		storage[stolen_id] -= 1
		if storage[stolen_id] <= 0:
			storage.erase(stolen_id)
		storage_updated.emit()
	else:  # cabinet
		# 
		var removed: bool = false
		for cab_id in cabinet_items:
			if removed:
				break
			var items: Array = cabinet_items[cab_id]
			var idx: int = items.find(stolen_id)
			if idx >= 0:
				items.remove_at(idx)
				removed = true
	
	var source_name: String = "" if target["source"] == "storage" else ""
	return "[color=orange]%s%s %s ×1[/color]" % [thief_name, source_name, stolen_name]


func get_combat_npcs() -> int:
	""""""
	var count := 0
	for npc in room_npcs:
		if npc.get("type", "") == "survivor":
