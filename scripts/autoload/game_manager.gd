func ask_sister_for_quest() -> String:
	""" → 2"""
	if sister_dead:
		return "妹妹已经不在了..."
	if sister_saved:
		return "妹妹已经康复了~"
	
	# 2 → 
	if sister_quests_issued_today >= 2:
		return "妹妹没有别的想要的了~"
	
	# 2
	var items_to_add: Array
	var all_craftable = CRAFT_RECIPES.keys()
	
	#  → 
	if not sister_cold_medicine_quested:
		if not sister_quest_items.has("cold_medicine"):
			items_to_add.append("cold_medicine")
			sister_cold_medicine_quested = true
	
	# 2
	var today_remaining := 2 - sister_quests_issued_today
	while items_to_add.size() < today_remaining:
		var pool: Array[String] = []
		for item in all_craftable:
			if not sister_quest_items.has(item):
				var already_adding := false
				for a in items_to_add:
					if a == item:
						already_adding = true
						break
				if not already_adding:
					var idx := find_item(item)
					if idx < 0:  # 
						pool.append(item)
		if pool.is_empty():
			# 
			for item in all_craftable:
				if not sister_quest_items.has(item):
					var already_adding := false
					for a in items_to_add:
						if a == item:
							already_adding = true
							break
					if not already_adding:
						pool.append(item)
		if pool.is_empty():
			break
		pool.shuffle()
		items_to_add.append(pool[0])
	
	# 
	for item in items_to_add:
		sister_quest_items.append(item)
		sister_quests_issued_today += 1
	
	# 
	if items_to_add.is_empty():
		if sister_quests_issued_today >= 2:
			return "妹妹没有别的想要的了~"
		elif sister_quest_count() > 0:
			return "" + get_sister_quest_label() + ""
		else:
			return "妹妹暂时不需要更多东西了..."
	
	# 
	var new_names: Array[String] = []
	for item in items_to_add:
		new_names.append("%s" % ITEM_DATA.get(item, {}).get("name", "???"))
	
	# 
	if "cold_medicine" in items_to_add and not sister_saved:
		return "/............"
	
	if items_to_add.size() >= 2:
		return " %s" % "  ".join(new_names)
	else:
		return " %s" % new_names[0]


