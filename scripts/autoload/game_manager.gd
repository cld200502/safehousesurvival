func pick_random_npc() -> Dictionary:
	var available := []
	for npc in npc_pool:
		var nid: String = npc.get("name", "") + "_" + str(npc_pool.find(npc))
		if nid not in npcs_used_today:
			available.append(npc)
	if available.is_empty():
		available = npc_pool.duplicate(true)
	var chosen: Dictionary = available[randi() % available.size()]
	npcs_used_today.append(chosen.get("name", "") + "_" + str(npc_pool.find(chosen)))
	return chosen.duplicate(true)


func process_door_decision(accepted: bool) -> Dictionary:
	var npc := active_npc_data
	var ntype: String = npc.get("type", "zombie")
	var msg: String = ""
	var result := {"ok": true, "msg": "", "hp_loss": 0, "sanity_loss": 0, "reward": ""}

	if accepted:
		match ntype:
			"survivor":
				if room_npcs.size() >= MAX_ROOM_NPCS:
					msg = "%s进了门，但安全屋里已经没地方了...\n%s无奈地离开了。" % [npc.get("name", ""), npc.get("name", "")]
					result["ok"] = false
				else:
					msg = "%s进了门，看起来松了口气。\n" % npc.get("name", "")
					var thanks: String = npc.get("thanks_dialog", "谢了，兄弟。")
					msg += thanks
					var reward: String = npc.get("reward", "")
					if reward != "":
						add_item(reward)
						msg += "\n[color=green]获得: %s[/color]" % ITEM_DATA.get(reward, {}).get("name", reward)
					add_room_npc(npc)
					modify_morality(+5, "收留幸存者")
					init_npc_relation(npc.get("name", ""), +15)
			"hidden_infected":
				# 隐藏感染者
				if room_npcs.size() >= MAX_ROOM_NPCS:
					msg = "%s进了门，但安全屋里已经没地方了...\n%s无奈地离开了。" % [npc.get("name", ""), npc.get("name", "")]
					result["ok"] = false
				else:
					msg = "%s进了门，看起来松了口气。\n" % npc.get("name", "")
					var hthanks: String = npc.get("thanks_dialog", "谢了，兄弟。")
					msg += hthanks
					var hreward: String = npc.get("reward", "")
					if hreward != "":
						add_item(hreward)
						msg += "\n[color=green]获得: %s[/color]" % ITEM_DATA.get(hreward, {}).get("name", hreward)
					make_hidden_infected(npc)
					modify_morality(+3, "收留幸存者")
					init_npc_relation(npc.get("name", ""), +10)
			"imposter":
				if room_npcs.size() >= MAX_ROOM_NPCS:
					msg = "%s进了门，但安全屋里已经没地方了...\n%s无奈地离开了。" % [npc.get("name", ""), npc.get("name", "")]
					result["ok"] = false
				else:
					msg = "%s进了门，看起来松了口气。\n" % npc.get("name", "")
					add_room_npc(npc)
					make_hidden_infected(npc)
					modify_morality(+1, "收留幸存者")
					init_npc_relation(npc.get("name", ""), +5)
			"zombie":
				msg = "打开门发现是一只丧尸！\n你被丧尸抓伤了..."
				modify_hp(-25)
				add_kill()
				result["hp_loss"] = 25
				result["ok"] = false
	else:
		match ntype:
			"survivor":
				msg = "你没有开门。\n门外的人等了一会儿，默默离开了……\n你感到一阵内疚。"
				modify_sanity(-15)
				modify_morality(-8, "拒绝幸存者")
				result["sanity_loss"] = 15
			"hidden_infected":
				msg = "你没有开门。\n门外的人站了一会儿，然后离开了……\n"
				modify_sanity(-5)
				modify_morality(-2, "拒绝幸存者")
				result["sanity_loss"] = 5
			"imposter":
				msg = "你没有开门。\n门外的人站了一会儿，然后离开了……\n"
				modify_sanity(-5)
				modify_morality(+1, "拒绝冒名者")
				result["sanity_loss"] = 5
			"zombie":
				msg = "你没有开门。\n丧尸在门外徘徊了一会儿，最终离开了。"

	result["msg"] = msg
	active_npc_data = {}
	npc_door_result.emit(accepted, npc)
	return result


