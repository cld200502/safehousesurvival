func craft_item(recipe_id: String) -> String:
	""""""
	if not CRAFT_RECIPES.has(recipe_id):
		return ""
	if not can_craft(recipe_id):
		return ""
	if inventory.size() >= MAX_INVENTORY and find_item(recipe_id) < 0:
		return ""

	var mats: Dictionary = CRAFT_RECIPES[recipe_id]["materials"]
	# 
	for mat_id in mats:
		var needed: int = mats[mat_id]
		var inv_idx := find_item(mat_id)
		var from_inv := mini(needed, inventory[inv_idx]["amount"] if inv_idx >= 0 else 0)
		var from_storage := needed - from_inv
		if from_inv > 0:
			remove_item(mat_id, from_inv)
		if from_storage > 0:
			storage[mat_id] -= from_storage
			if storage[mat_id] <= 0:
				storage.erase(mat_id)
	storage_updated.emit()

	add_item(recipe_id)
	# 1
	consume_actions(1)
	return " %s" % ITEM_DATA.get(recipe_id, {}).get("name", recipe_id)


