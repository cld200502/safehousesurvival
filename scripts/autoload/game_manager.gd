func _process(_delta: float) -> void:
	var target: float = SPEED_SCALE * speed_multiplier
	if Engine.time_scale != target:
		Engine.time_scale = target


func _ready() -> void:
	process_mode = Node.PROCESS_MODE_ALWAYS  # time_scale
	_init_npc_pool()
	_init_explore_locations()
	reset_game()
	Engine.time_scale = SPEED_SCALE * speed_multiplier


