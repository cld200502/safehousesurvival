func do_day_passive() -> void:
	# 5
	if current_day >= 5:
		trigger_ending()
		return

	# 50%
	sanity = clampf(sanity * 1.5, 0.0, 100.0)
	sanity_changed.emit(sanity)

	door_reinforced_today = false

	if hunger <= 0:
		modify_hp(-15)
		message_shown.emit("[color=red]你饿极了...感到头晕目眩（生命 -15）[/color]", 2.0)

	# ===== 20% =====
	var hunger_pct := hunger / max_hunger * 100.0
	if hunger_pct <= 20.0 and hunger_pct > 0:
		message_shown.emit("[color=orange][b]你的肚子咕咕直叫，急需食物！[/b][/color]", 3.0)
	elif hunger_pct <= 0:
		message_shown.emit("[color=red][b]你已经饿到极限了，再不进食就会撑不住了！[/b][/color]", 3.0)

	var hp_pct := float(hp) / float(max_hp) * 100.0
	if hp_pct <= 20.0 and hp > 0:
		message_shown.emit("[color=red][b]你的伤势很严重，生命危在旦夕！[/b][/color]", 3.0)

	if sanity / 100.0 <= 0.2 and sanity > 5:
		message_shown.emit("[color=purple][b]你感到精神恍惚...视野中出现了幻觉...[/b][/color]", 3.0)
	elif sanity <= 5:
		message_shown.emit("[color=purple]你的理智濒临崩溃...[/color]", 2.0)

	# 5%
	var decay := maxi(1, int(ceil(door_max_hp * 0.05)))
	door_hp = maxi(0, door_hp - decay)
	door_state_changed.emit(door_hp, door_max_hp, door_reinforce_level)

	# 20%
	var door_pct := float(door_hp) / float(door_max_hp)
	if door_pct <= 0.2 and door_pct > 0.0:
		message_shown.emit("[color=red][b](%d%%)\n...[/b][/color]" % int(door_pct * 100), 4.0)
	elif door_pct <= 0.5 and door_pct > 0.2:
		message_shown.emit("[color=orange](%d%%)...[/color]" % int(door_pct * 100), 2.5)
	# P3: 
	var spoiled := get_all_spoiled_items()
	if not spoiled.is_empty():
		var names: Array = []
		for sid in spoiled:
			names.append(ITEM_DATA.get(sid, {}).get("name", sid))
		message_shown.emit("[color=red]%s[/color]" % ", ".join(names), 3.0)


func is_night() -> bool:
	return current_hour >= NIGHT_START or current_hour < DAY_START


func is_midnight() -> bool:
	return must_sleep or actions_today >= ACTIONS_PER_DAY


