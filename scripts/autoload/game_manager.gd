func reinforce_door() -> String:
	if door_reinforced_today:
		return "今天已经加固过了"
	if get_actions_left() < 1:
		return "行动力不足"
	door_reinforce_level += 1
	door_reinforced_today = true
	door_max_hp = 100 + door_reinforce_level * 20
	door_hp = door_max_hp
	consume_actions(1)
	door_state_changed.emit(door_hp, door_max_hp, door_reinforce_level)
	return "房门加固完成！加固等级：Lv.%d  耐久：%d/%d" % [door_reinforce_level, door_hp, door_max_hp]


func repair_door() -> String:
	if door_hp >= door_max_hp:
		return "房门耐久已满"
	if get_actions_left() < 1:
		return "行动力不足"
	door_hp = mini(door_hp + 30, door_max_hp)
	consume_actions(1)
	door_state_changed.emit(door_hp, door_max_hp, door_reinforce_level)
	return "房门修理完成！耐久：%d/%d" % [door_hp, door_max_hp]


func damage_door(amount: int) -> void:
	door_hp = maxi(0, door_hp - amount)
	door_state_changed.emit(door_hp, door_max_hp, door_reinforce_level)
	if door_hp <= 0:
		message_shown.emit("[color=red][/color]", 4.0)


func get_door_difficulty() -> String:
	"""QTE"""
	var base := door_reinforce_level
	var zlv := zombie_level
	var score := base - zlv + 2
	if score <= 0:
		return "hard"
	elif score <= 1:
		return "normal"
	else:
		return "easy"


const MAX_ROOM_NPCS: int = 5

func add_room_npc(npc_data: Dictionary) -> bool:
	"""NPCfalse"""
	for rnpc in room_npcs:
		if rnpc.get("name", "") == npc_data.get("name", ""):
			return true  # 
	if room_npcs.size() >= MAX_ROOM_NPCS:
		return false
	var data := npc_data.duplicate(true)
	data["asked_count"] = 0  # 
	data["_join_day"] = current_day  # 
	room_npcs.append(data)
	return true


func make_hidden_infected(npc_data: Dictionary) -> bool:
	"""NPC
	20%30%40%10%"""
	if not add_room_npc(npc_data):
		return false
	# NPC
	for rnpc in room_npcs:
		if rnpc.get("name", "") == npc_data.get("name", ""):
			rnpc["type"] = "hidden_infected"
			var roll := randf()
			if roll < 0.20:
				rnpc["_transform_night"] = 1  # 
			elif roll < 0.50:
				rnpc["_transform_night"] = 2  # 
			elif roll < 0.90:
				rnpc["_transform_night"] = 3  # 
			else:
				rnpc["_transform_night"] = 99  # 
			break
	return true


func process_hidden_infected_night() -> Dictionary:
	"""
	{names: NPC, events: , has_combat: }"""
	var result := {"names": [], "events": [], "has_combat": false}
	for npc in room_npcs:
		if npc.get("type", "") != "hidden_infected":
			continue
		var transform_night: int = npc.get("_transform_night", 99)
		var join_day: int = npc.get("_join_day", current_day)
		var days_passed: int = current_day - join_day + 1  # 
		if days_passed >= transform_night:
			var npc_name: String = npc.get("name", "???")
			npc["type"] = "mutated"
			result["names"].append(npc_name)
			result["events"].append("[color=red]%s在夜里发出一声痛苦的嘶吼——\nTA的身体开始扭曲变形，瞳孔变成了灰色。\nTA已经彻底变异了。[/color]" % npc_name)
			result["has_combat"] = true
	return result


func remove_room_npc(npc_name: String) -> void:
	"""NPC/"""
	for i in room_npcs.size():
		if room_npcs[i].get("name", "") == npc_name:
			room_npcs.remove_at(i)
			_kicked_npc_names.append(npc_name)  # NPC
			return


func get_kicked_npc_summary() -> Array[String]:
	"""NPC"""
	var msgs: Array[String] = []
	for name in _kicked_npc_names:
		msgs.append("[color=yellow]%s[/color]" % name)
	_kicked_npc_names.clear()
	return msgs


func get_room_npc_by_name(npc_name: String) -> Dictionary:
	"""NPC"""
	for npc in room_npcs:
		if npc.get("name", "") == npc_name:
			return npc
	return {}


func check_npc_mutation(npc_name: String) -> int:
	"""NPC0=, 1=(), 2="""
	var npc := get_room_npc_by_name(npc_name)
	if npc.is_empty():
		return -1
	var ntype: String = npc.get("type", "survivor")
	if ntype == "mutated":
		return 2
	if ntype == "imposter":
		# 50%
		if randf() < 0.5:
			return 1
	if ntype == "hidden_infected":
		# QTE100%
		return 1
	# 5%
	if ntype == "survivor" and randf() < 0.05:
		npc["type"] = "infected"
		return 1
	return 0


func extort_room_npc(npc_name: String, qte_success: bool = true) -> String:
	"""勒索NPC：qte_success表示QTE是否成功"""
	var npc := get_room_npc_by_name(npc_name)
	if npc.is_empty():
		return "[color=yellow]该NPC已不存在。[/color]"
	var ntype: String = npc.get("type", "survivor")
	var nname: String = npc.get("name", "???")
	# QTE失败 → 勒索失败
	if not qte_success:
		npc["was_extorted"] = true
		modify_sanity(-8)
		modify_morality(-6, "勒索%s失败" % nname)
		modify_npc_relation(npc_name, -20)
		return "[color=orange]勒索失败！\n%s 冷冷地看着你：\n\"别以为这样可以吓到我。\"\n[color=yellow]精神-8[/color][/color]" % nname

	match ntype:
		"imposter":
			# 伪装者反击
			modify_hp(-10)
			modify_sanity(-15)
			modify_morality(-4, "勒索伪装者%s" % nname)
			npc["was_extorted"] = true
			return "[color=red]%s突然暴起反击！\n\"你以为我是谁？敢勒索我？！\"\nTA一拳打在你脸上。\n[color=red]HP-10  精神-15[/color][/color]" % nname
		"mutated":
			modify_hp(-30)
			return "[color=red]%s的变异躯体爆发出惊人的力量！\nTA疯狂地攻击了你！\n[color=red]HP-30[/color][/color]" % nname
		_:
			# 幸存者 → 勒索成功获得物品
			var items := ["cloth", "wood_stick", "food", "herb", "medicine"]
			var gift: String = items[randi() % items.size()]
			add_item(gift)
			npc["was_extorted"] = true
			modify_morality(-10, "勒索NPC%s" % nname)
			modify_npc_relation(npc_name, -25)
			# 65%概率2-3天后离开
			if randf() < 0.65:
				var delay := randi_range(2, 3)
				var join_day: int = npc.get("_join_day", current_day)
				npc["leave_day"] = join_day + delay
				return "[color=yellow]%s哆嗦着交出了物品：\n\"别伤害我...拿去就是了...\"\n[color=green]获得: %s[/color]\n\n[i]TA开始收拾行李，看起来打算在%d天后离开...[/i][/color]" % [nname, ITEM_DATA.get(gift, {}).get("name", gift), delay]
			else:
				return "[color=yellow]%s惊恐地递过物品：\n\"好...好吧，给你就是了...\"\n[color=green]获得: %s[/color]\n\n[i]TA低下头，眼中充满了恐惧...[/i][/color]" % [nname, ITEM_DATA.get(gift, {}).get("name", gift)]


func talk_to_room_npc(npc_data: Dictionary) -> String:
	var ntype: String = npc_data.get("type", "survivor")
	var name: String = npc_data.get("name", "???")
	match ntype:
		"survivor":
			var talks := [
				"今天天气还行，希望丧尸别太多...",
				"你有多的绷带吗？我的伤口又裂开了。",
				"我昨晚听到外面有动静，好像不是丧尸...",
				"说实话，能活着到这里，我已经很知足了。",
			]
			return "%s: %s" % [name, talks[randi() % talks.size()]]
		"imposter":
			return "%s冷冷地看了你一眼，没有多说什么。" % name
		"mutated":
			return "%s发出低沉的喉音，眼神涣散...TA已经无法交流了。" % name
		"hidden_infected":
			var hi_talks := [
				"%s: ..." % name,
				"%s: " % name,
				"%s: ..." % name,
				"%s: ..." % name,
				"%s: " % name,
			]
			return hi_talks[randi() % hi_talks.size()]
	return "%s" % name


func get_backstory_for_npc(npc_name: String) -> Array:
	"""NPC"""
	var npc := get_room_npc_by_name(npc_name)
	if npc.is_empty():
		return []
	return npc.get("backstory", [])


func ask_npc_question(npc_name: String, question_idx: int) -> String:
	"""NPCquestion_idx0"""
	var npc := get_room_npc_by_name(npc_name)
	if npc.is_empty():
		return "NPC"
	var backstory: Array = npc.get("backstory", [])
	if question_idx < 0 or question_idx >= backstory.size():
		return "%s: ... TA" % npc_name
	var asked: int = npc.get("asked_count", 0)
	if question_idx > asked:
		return "..."
	# 
	npc["asked_count"] = asked + 1
	var qa: Dictionary = backstory[question_idx]
	return "%s: %s" % [npc_name, qa.get("a", "...")]


