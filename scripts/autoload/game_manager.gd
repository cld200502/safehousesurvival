func trigger_ending() -> void:
	"""第5天触发，根据数值判定10个结局"""
	game_over = true
	var npc_count: int = room_npcs.size()
	var ending_id: String = "tomorrow_never"
	
	# 按照优先级检查结局条件（sister_waltz优先于last_light等）
	for ending in ENDINGS:
		var cond: String = ending.get("condition", "")
		if cond == "":
			continue  # 跳过兜底结局，最后再分配
		if _check_ending_condition(cond, npc_count):
			ending_id = ending.get("id", "tomorrow_never")
			break
	
	var data := {
		"day": current_day,
		"hour": current_hour,
		"kills": kill_count,
		"morality": morality,
		"npc_count": npc_count,
		"sanity": sanity,
		"hp": hp,
		"zombie_level": zombie_level,
		"door_hp": door_hp,
		"door_max": door_max_hp,
	}
	ending_triggered.emit(ending_id, data)


func _check_ending_condition(cond: String, npc_count: int) -> bool:
	"""解析并检查结局条件表达式 (格式: key>=val && key<=val ...)"""
	if cond.strip_edges() == "":
		return false
	
	var parts := cond.split("&&")
	for part in parts:
		var trimmed := part.strip_edges()
		if trimmed == "":
			continue
		
		# 解析比较表达式: key >= val 或 key <= val 或 key == val
		var op := ""
		var key := ""
		var val_str := ""
		
		if ">=" in trimmed:
			op = ">="
		elif "<=" in trimmed:
			op = "<="
		elif "==" in trimmed:
			op = "=="
		elif ">" in trimmed:
			op = ">"
		elif "<" in trimmed:
			op = "<"
		else:
			continue
		
		var split_parts := trimmed.split(op)
		if split_parts.size() < 2:
			continue
		key = split_parts[0].strip_edges()
		val_str = split_parts[1].strip_edges()
		
		if not val_str.is_valid_int() and not val_str.is_valid_float():
			continue
		var val: float = float(val_str)
		
		# 获取变量值
		var actual_val: float = 0.0
		match key:
			"npc_count": actual_val = float(npc_count)
			"morality": actual_val = float(morality)
			"sanity": actual_val = sanity
			"kills": actual_val = float(kill_count)
			_: continue
		
		# 执行比较
		match op:
			">=": if not (actual_val >= val): return false
			"<=": if not (actual_val <= val): return false
			"==": if not (actual_val == val): return false
			">":  if not (actual_val > val):  return false
			"<":  if not (actual_val < val):  return false
			_: return false
	
	return true


func trigger_game_over(reason: String) -> void:
	game_over = true
	game_over_triggered.emit(current_day, current_hour, reason, kill_count)


