# ====================  ====================
func add_item(item_id: String, amount: int = 1) -> bool:
	"""false"""
	var idx := find_item(item_id)
	if idx >= 0:
		inventory[idx]["amount"] += amount
	else:
		if inventory.size() >= MAX_INVENTORY:
			popup_message.emit("%s\n(%d/%d)" % [ITEM_DATA.get(item_id, {}).get("name", item_id), inventory.size(), MAX_INVENTORY])
			return false
		inventory.append({"id": item_id, "amount": amount})
	# P3: 
	if FOOD_CATEGORIES.has(item_id):
		for i in range(amount):
			item_spawn_days["%s_%d" % [item_id, inventory.size() + i]] = current_day
	inventory_updated.emit()
	return true


func remove_item(item_id: String, amount: int = 1) -> bool:
	var idx := find_item(item_id)
	if idx < 0 or inventory[idx]["amount"] < amount:
		return false
	inventory[idx]["amount"] -= amount
	if inventory[idx]["amount"] <= 0:
		inventory.remove_at(idx)
	inventory_updated.emit()
	return true


func has_item(item_id: String, amount: int = 1) -> bool:
	var idx := find_item(item_id)
	return idx >= 0 and inventory[idx]["amount"] >= amount


func find_item(item_id: String) -> int:
	for i in inventory.size():
		if inventory[i]["id"] == item_id:
			return i
	return -1


func get_inventory_count() -> int:
	var total := 0
	for item in inventory:
		total += item["amount"]
	return total


func use_item_by_index(idx: int) -> String:
	if idx < 0 or idx >= inventory.size():
		return ""
	var item_id: String = inventory[idx]["id"]
	var data: Dictionary = ITEM_DATA.get(item_id, {})
	var name_str: String = data.get("name", item_id)
	if data.get("type", "") != "consumable":
		return "[color=gray]%s不可使用[/color]" % name_str
	# P3: 食物变质检查
	if FOOD_CATEGORIES.has(item_id):
		var spoil_status: int = _get_food_spoil_status(item_id, idx)
		if spoil_status == 2:
			remove_item(item_id)
			item_used.emit(item_id)
			return "%s[color=red]已腐烂！HP-15 精神-10[/color]" % name_str
		elif spoil_status == 1:
			message_shown.emit("[color=yellow]%s快过期了...[/color]" % name_str, 2.0)
	remove_item(item_id)
	_apply_item_effect(data, item_id, idx)
	item_used.emit(data.get("name", item_id))
	# 构建使用结果描述（解析effect字段）
	var eff: String = data.get("effect", "")
	var eff_parts := eff.split(",")
	var effects_desc: Array[String] = []
	for part in eff_parts:
		part = part.strip_edges()
		if part.begins_with("hp+"):
			effects_desc.append("[color=green]HP+%s[/color]" % part.substr(3))
		elif part.begins_with("hp-"):
			effects_desc.append("[color=red]HP%s[/color]" % part.substr(2))
		elif part.begins_with("hunger+"):
			effects_desc.append("[color=green]饥饿度+%s[/color]" % part.substr(7))
		elif part.begins_with("hunger-"):
			effects_desc.append("[color=orange]饥饿度%s[/color]" % part.substr(6))
		elif part.begins_with("sanity+"):
			effects_desc.append("[color=green]精神+%s[/color]" % part.substr(7))
		elif part.begins_with("sanity-"):
			effects_desc.append("[color=red]精神%s[/color]" % part.substr(6))
	if effects_desc.is_empty():
		return "[color=green]%s[/color]" % name_str
	return "[color=green]%s → %s[/color]" % [name_str, " ".join(effects_desc)]


func _get_food_spoil_status(item_id: String, inv_idx: int) -> int:
	""": 0= 1= 2="""
	var cat: int = FOOD_CATEGORIES.get(item_id, -1)
	if cat == -1 or cat == FoodCategory.CANNED:
		return 0
	var max_days: int = FOOD_SPOIL_DAYS.get(cat, 999)
	var key: String = "%s_%d" % [item_id, inv_idx]
	var spawn_day: int = item_spawn_days.get(key, current_day)
	var age: int = current_day - spawn_day
	if age >= max_days + 1:
		return 2   # 1
	elif age >= max_days:
		return 1   # 
	return 0


func get_food_label(item_id: String, inv_idx: int) -> String:
	"""UI"""
	var status: int = _get_food_spoil_status(item_id, inv_idx)
	match status:
		0: return ""
		1: return "[color=#cccc66]()[/color]"
		2: return "[color=#ff4444]()[/color]"
	return ""


func get_all_spoiled_items() -> Array[String]:
	"""ID"""
	var result: Array[String] = []
	for i in range(inventory.size()):
		var iid: String = inventory[i]["id"]
		if FOOD_CATEGORIES.has(iid) and _get_food_spoil_status(iid, i) == 2:
			result.append(iid)
	return result


func _apply_item_effect(data: Dictionary, item_id: String = "", inv_idx: int = -1) -> void:
	# P3: 
	if item_id != "" and inv_idx >= 0 and FOOD_CATEGORIES.has(item_id):
		var status: int = _get_food_spoil_status(item_id, inv_idx)
		if status == 2:
			#  + HP
			modify_hp(-15)
			modify_sanity(-10)
			message_shown.emit("[color=red]... HP-15 -10[/color]", 3.0)
			# 
			var effect: String = data.get("effect", "")
			var parts := effect.split(",")
			for part in parts:
				if part.begins_with("hp+"):
					modify_hp(int(float(part.substr(3)) * 0.5))
				elif part.begins_with("hunger+"):
					modify_hunger(float(part.substr(7)) * 0.5)
				elif part.begins_with("sanity+"):
					modify_sanity(float(part.substr(8)) * 0.5)
			return
	var effect: String = data.get("effect", "")
	var parts := effect.split(",")
	for part in parts:
		if part.begins_with("hp+"):
			modify_hp(int(part.substr(3)))
		elif part.begins_with("hunger+"):
			modify_hunger(float(part.substr(7)))
		elif part.begins_with("sanity+"):
			modify_sanity(float(part.substr(7)))


# ====================  ====================
func equip_weapon(slot: String, item_id: String) -> String:
	""""""
	var item_data: Dictionary = ITEM_DATA.get(item_id, {})
	if item_data.get("type", "") != "weapon":
		return "%s" % item_data.get("name", item_id)
	if not has_item(item_id):
		return "%s" % item_data.get("name", item_id)
	var current: String = equip_left if slot == "left" else equip_right
	if current != "":
		# 
		add_item(current)
	if slot == "left":
		equip_left = item_id
	else:
		equip_right = item_id
	remove_item(item_id)
	equipment_changed.emit()
	return " %s %s" % [item_data.get("name", item_id), "" if slot == "left" else ""]


func unequip_weapon(slot: String) -> String:
	var current: String = equip_left if slot == "left" else equip_right
	if current == "":
		return ""
	if not add_item(current):
		# 
		return ""
	if slot == "left":
		equip_left = ""
	else:
		equip_right = ""
	equipment_changed.emit()
	return " %s" % ITEM_DATA.get(current, {}).get("name", current)


func get_total_damage() -> int:
	"""100%50%"""
	var total := 0
	if equip_left != "":
		total += ITEM_DATA.get(equip_left, {}).get("damage", 0)
	if equip_right != "":
		#  50% =100
		var offhand_dmg: int = ITEM_DATA.get(equip_right, {}).get("damage", 0)
		total += offhand_dmg / 2
	return total


# ====================  ====================
func store_item(item_id: String, amount: int = 1) -> bool:
	""""""
	if not has_item(item_id, amount):
		return false
	remove_item(item_id, amount)
	if storage.has(item_id):
		storage[item_id] += amount
	else:
		storage[item_id] = amount
	storage_updated.emit()
	return true


func store_all_items() -> int:
	""""""
	var items_to_store: Array = inventory.duplicate(true)
	var stored_count: int = 0
	for item in items_to_store:
		var item_id: String = item["id"]
		var amount: int = item["amount"]
		if store_item(item_id, amount):
			stored_count += 1
	return stored_count


func take_from_storage(item_id: String, amount: int = 1) -> bool:
	""""""
	if not storage.has(item_id) or storage[item_id] < amount:
		return false
	if inventory.size() >= MAX_INVENTORY and find_item(item_id) < 0:
		popup_message.emit("背包已满，无法取出物品")
		return false
	storage[item_id] -= amount
	if storage[item_id] <= 0:
		storage.erase(item_id)
	add_item(item_id, amount)
	storage_updated.emit()
	return true


func get_storage_count(item_id: String) -> int:
	return storage.get(item_id, 0)


