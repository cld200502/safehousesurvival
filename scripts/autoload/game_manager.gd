func discard_to_trash(item_id: String, amount: int = 1) -> bool:
	""""""
	if not has_item(item_id, amount):
		return false
	remove_item(item_id, amount)
	if trash_bin.has(item_id):
		trash_bin[item_id] += amount
	else:
		trash_bin[item_id] = amount
	trash_updated.emit()
	return true


func take_from_trash(item_id: String, amount: int = 1) -> bool:
	""""""
	if not trash_bin.has(item_id) or trash_bin[item_id] < amount:
		return false
	if inventory.size() >= MAX_INVENTORY and find_item(item_id) < 0:
		popup_message.emit("背包已满，无法从垃圾桶取出物品")
		return false
	trash_bin[item_id] -= amount
	if trash_bin[item_id] <= 0:
		trash_bin.erase(item_id)
	add_item(item_id, amount)
	trash_updated.emit()
	return true


func take_all_from_trash() -> int:
	""""""
	var count: int = 0
	var to_take: Array = []
	for item_id in trash_bin:
		to_take.append(item_id)
	for item_id in to_take:
		if not trash_bin.has(item_id):
			continue
		while trash_bin.get(item_id, 0) > 0:
			if inventory.size() >= MAX_INVENTORY and find_item(item_id) < 0:
				popup_message.emit("背包已满，无法继续取出物品")
				return count
			trash_bin[item_id] -= 1
			if trash_bin[item_id] <= 0:
				trash_bin.erase(item_id)
			add_item(item_id)
			count += 1
	trash_updated.emit()
	return count


func get_trash_count(item_id: String) -> int:
	return trash_bin.get(item_id, 0)


