func can_craft(recipe_id: String) -> bool:
	if not CRAFT_RECIPES.has(recipe_id):
		return false
	var mats: Dictionary = CRAFT_RECIPES[recipe_id]["materials"]
	for mat_id in mats:
		var needed: int = mats[mat_id]
		var have: int = 0
		var inv_idx := find_item(mat_id)
		if inv_idx >= 0:
			have += inventory[inv_idx]["amount"]
		have += storage.get(mat_id, 0)
		if have < needed:
			return false
	return true


